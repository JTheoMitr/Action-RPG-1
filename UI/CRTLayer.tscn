[gd_scene load_steps=3 format=2]

[sub_resource type="Shader" id=101]
code = "shader_type canvas_item;

uniform float scanline_strength = 0.15; // was .06
uniform float brightness = 1.0;
uniform float flicker_strength = 0.002;
uniform float flicker_enabled = 0.0;

void fragment() {
	vec2 uv = SCREEN_UV;
	vec4 col = texture(SCREEN_TEXTURE, uv);

	// Smooth scanlines (0 → 1 range)
	float scan = (sin(uv.y * 800.0) * 0.5 + 0.5) * scanline_strength;

	// Apply as multiplier instead of subtract
	col.rgb *= 1.0 - scan;

	// Optional flicker
//	if (flicker_enabled > 0.5) {
//		float flicker = sin(TIME * 60.0) * flicker_strength;
//		col.rgb += vec3(flicker);
//	}

	col.rgb *= brightness;
	COLOR = vec4(col.rgb, 1.0);
}"

